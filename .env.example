# --- API-Football credentials (server-side ONLY) ---
# These are read by the serverless proxy in /api. They are NEVER exposed to the
# browser. Do not prefix them with VITE_ (that would inline them into the bundle).
#
# Sign up at https://www.api-football.com/ (direct) or via RapidAPI, then put your
# key here. With no key, the app runs on its static seed snapshot and the mascot
# simply holds at its real current state — it never advances on fabricated data.

# If you use the direct API-Sports host:
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io

# If instead you use RapidAPI, set the key above and switch the host to:
# API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com
# (the proxy auto-detects the RapidAPI host and sends the right headers)

# FIFA World Cup league id + season on API-Football (confirm against your plan).
WC_LEAGUE_ID=1
WC_SEASON=2026
