# --- Highlightly Football API (server-side ONLY) ---
# Read by the serverless proxy in /api. NEVER exposed to the browser — do not
# prefix with VITE_ (that would inline it into the bundle). With no key, the app
# runs on its static seed snapshot and never advances on fabricated data.
#
# Get a key at https://highlightly.net/ (free Basic tier). The direct platform
# (https://soccer.highlightly.net) authenticates with the x-rapidapi-key header.
# Put the REAL key in .env.local (gitignored), not in this example file.

HIGHLIGHTLY_KEY=
WC_LEAGUE_ID=1635
WC_SEASON=2026

# --- Supabase (login + league leaderboard) ---
# These two are PUBLIC by design — the anon key is meant to ship in the browser
# bundle, and every write is guarded by row-level-security on the server. Leaving
# them blank keeps the login/league layer fully dormant (no Sign-in button, no
# League tab); the app runs exactly as before on localStorage.
#
# NEVER put the Supabase *service_role* key here or in any VITE_ var — it bypasses
# RLS and must stay server-side only (we don't use it in this app).
#
# Get these from Supabase → Project Settings → API. See docs/league-setup.md.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
